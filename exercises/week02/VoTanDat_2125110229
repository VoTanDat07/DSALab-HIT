            cout << "Gia tri = " << v.at(i) << endl;

            break;
        }

        case 4:

            v.print();

            break;

        case 0:

            break;

        default:

            cout << "Lua chon khong hop le!\n";
        }

    } while (choice != 0);
}

/* =====================================================
   QUAN LY SINH VIEN
===================================================== */

struct Student {

    char name[50];
    char id[20];
    float score;
};

class StudentManager {

private:

    Student* data;
    int size;
    int capacity;

public:

    StudentManager() {

        size = 0;
        capacity = 2;

        data = new Student[capacity];
    }

    ~StudentManager() {
        delete[] data;
    }

    void resize() {

        capacity *= 2;

        Student* newData = new Student[capacity];

        for (int i = 0; i < size; i++) {
            newData[i] = data[i];
        }

        delete[] data;

        data = newData;
    }

    void addStudent() {

        if (size == capacity) {
            resize();
        }

        cin.ignore();

        cout << "Nhap ten: ";
        cin.getline(data[size].name, 50);

        cout << "Nhap MSSV: ";
        cin.getline(data[size].id, 20);

        cout << "Nhap diem: ";
        cin >> data[size].score;

        size++;

        cout << "Them thanh cong!\n";
    }

    void showStudents() {

        cout << "\n===== DANH SACH =====\n";

        for (int i = 0; i < size; i++) {

            cout << i + 1 << ". ";

            cout << data[i].name
                << " | " << data[i].id
                << " | " << data[i].score
                << endl;
        }
    }

    void deleteStudent() {

        char id[20];

        cin.ignore();

        cout << "Nhap MSSV can xoa: ";
        cin.getline(id, 20);

        int pos = -1;

        for (int i = 0; i < size; i++) {

            if (strcmp(data[i].id, id) == 0) {

                pos = i;
                break;
            }
        }

        if (pos == -1) {

            cout << "Khong tim thay!\n";
            return;
        }

        for (int i = pos; i < size - 1; i++) {
            data[i] = data[i + 1];
        }

        size--;

        cout << "Da xoa!\n";
    }

    void searchStudent() {

        char keyword[50];

        cin.ignore();

        cout << "Nhap ten hoac MSSV: ";
        cin.getline(keyword, 50);

        bool found = false;

        for (int i = 0; i < size; i++) {

            if (strcmp(data[i].name, keyword) == 0 ||
                strcmp(data[i].id, keyword) == 0) {

                cout << "\nTim thay:\n";

                cout << data[i].name
                    << " | " << data[i].id
                    << " | " << data[i].score
                    << endl;

                found = true;
            }
        }

        if (!found) {
            cout << "Khong tim thay!\n";
        }
    }

    void sortByScore() {

        for (int i = 0; i < size - 1; i++) {

            int minIndex = i;

            for (int j = i + 1; j < size; j++) {

                if (data[j].score < data[minIndex].score) {
                    minIndex = j;
                }
            }

            Student temp = data[i];
            data[i] = data[minIndex];
            data[minIndex] = temp;
        }

        cout << "Da sap xep!\n";
    }

    void statistics() {

        if (size == 0) {

            cout << "Danh sach rong!\n";
            return;
        }

        float max = data[0].score;
        float min = data[0].score;
        float sum = 0;

        for (int i = 0; i < size; i++) {

            if (data[i].score > max)
                max = data[i].score;

            if (data[i].score < min)
                min = data[i].score;

            sum += data[i].score;
        }

        cout << "\n===== THONG KE =====\n";

        cout << "Cao nhat: " << max << endl;
        cout << "Thap nhat: " << min << endl;
        cout << "Trung binh: " << sum / size << endl;
    }

    void exportFile() {

        ofstream file("diem_sinhvien.txt");

        for (int i = 0; i < size; i++) {

            file << data[i].name << " | "
                << data[i].id << " | "
                << data[i].score << endl;
        }

        file.close();

        cout << "Da xuat file!\n";
    }
};

