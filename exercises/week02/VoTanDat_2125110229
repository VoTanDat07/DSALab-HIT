/* =====================================================
   BAI 3 - VECTOR TU LAM
===================================================== */

class MyVector {

private:

    int* data;
    int size;
    int capacity;

public:

    MyVector() {

        size = 0;
        capacity = 2;

        data = new int[capacity];
    }

    ~MyVector() {
        delete[] data;
    }

    void resize() {

        capacity *= 2;

        int* newData = new int[capacity];

        for (int i = 0; i < size; i++) {
            newData[i] = data[i];
        }

        delete[] data;

        data = newData;
    }

    void push_back(int value) {

        if (size == capacity) {
            resize();
        }

        data[size] = value;
        size++;
    }

    void pop_back() {

        if (size > 0) {
            size--;
        }
    }

    int at(int index) {

        if (index < 0 || index >= size) {
            return -1;
        }

        return data[index];
    }

    void print() {

        cout << "Vector: ";

        for (int i = 0; i < size; i++) {
            cout << data[i] << " ";
        }

        cout << endl;
    }
};

