void bai1() {

    int n;

    cout << "\n===== BAI 1: MANG CO BAN =====\n";

    cout << "Nhap so phan tu: ";
    cin >> n;

    int a[1000];

    for (int i = 0; i < n; i++) {

        cout << "a[" << i << "] = ";
        cin >> a[i];
    }

    int minVal = a[0];
    int maxVal = a[0];
    int sum = 0;

    for (int i = 0; i < n; i++) {

        if (a[i] < minVal)
            minVal = a[i];

        if (a[i] > maxVal)
            maxVal = a[i];

        sum += a[i];
    }

    float avg = (float)sum / n;

    cout << "\n===== KET QUA =====\n";

    cout << "Min = " << minVal << endl;
    cout << "Max = " << maxVal << endl;
    cout << "Tong = " << sum << endl;
    cout << "Trung binh = " << avg << endl;
}

