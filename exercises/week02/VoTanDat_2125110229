void nhanMaTran() {

    int n;

    cout << "\n===== NHAN MA TRAN =====\n";

    cout << "Nhap n = ";
    cin >> n;

    int A[50][50];
    int B[50][50];
    int C[50][50];

    cout << "\nNhap ma tran A:\n";

    for (int i = 0; i < n; i++) {

        for (int j = 0; j < n; j++) {
            cin >> A[i][j];
        }
    }

    cout << "\nNhap ma tran B:\n";

    for (int i = 0; i < n; i++) {

        for (int j = 0; j < n; j++) {
            cin >> B[i][j];
        }
    }

    for (int i = 0; i < n; i++) {

        for (int j = 0; j < n; j++) {

            C[i][j] = 0;

            for (int k = 0; k < n; k++) {

                C[i][j] += A[i][k] * B[k][j];
            }
        }
    }
    cout << "\n===== KET QUA =====\n";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cout << C[i][j] << "\t";
        }
        cout << endl;
    }
}

void dinhThuc3x3() {
    int a[3][3];
    cout << "\n===== DINH THUC 3x3 =====\n";

    for (int i = 0; i < 3; i++) {

        for (int j = 0; j < 3; j++) {
            cin >> a[i][j];
        }
    }
    int det =
        a[0][0] * (a[1][1] * a[2][2] - a[1][2] * a[2][1])
        - a[0][1] * (a[1][0] * a[2][2] - a[1][2] * a[2][0])
        + a[0][2] * (a[1][0] * a[2][1] - a[1][1] * a[2][0]);

    cout << "\nDinh thuc = " << det << endl;
}

